# ── Provider: "ollama" (default) or "aifoundry" or "ghcopilot" ──
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=phi4
DEFAULT_TEMPERATURE=0.3

#DEFAULT_PROVIDER=aifoundry
#DEFAULT_MODEL=gpt-5.3-chat
#DEFAULT_TEMPERATURE=1

# ── Ollama (local inference) ──────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_NUM_CTX=8192

# ── Azure AI Foundry ─────────────────────────────────────────
# Works with any model deployed in Foundry: GPT-4o, Claude, Mistral, ...
AZURE_FOUNDRY_ENDPOINT=https://<your-name>.openai.azure.com/openai/v1
AZURE_FOUNDRY_API_KEY=<your-api-key>
AZURE_FOUNDRY_MODEL=gpt-5.3-chat

# ── GitHub Copilot (via Copilot SDK) HIGHLY EXPERIMENTAL ─────────────────────────
# This is highly experimental and may break agent functionality due to the SDK's opinionated architecture.
# Requires: GitHub Copilot CLI installed & authenticated (copilot --version)
GHCOPILOT_MODEL=claude-opus-4.6
# Optional: connect to a CLI running in headless mode (e.g. copilot --headless --port 4321)
#GHCOPILOT_CLI_URL=localhost:4321

# ── ChromaDB (vector memory) ─────────────────────────────────
CHROMA_PERSIST_DIR=./hybridagents/chroma_data
CHROMA_COLLECTION=agent_memory

# ── Agent loop ────────────────────────────────────────────────
MAX_LOOP_ITERATIONS=50
VERBOSE=true

# ── Privacy SDK ──────────────────────────────────────────────
# Privacy SDK to filter out personally identifiable information (PII) from messages.
# Auto-scrub messages before sending to aifoundry & ghcopilot provider (true/false)
# When PRIVACY_ENABLED=true, this is on by default - set to false to use sdk tools only.
PRIVACY_AUTO_FILTER=false

# Comma-separated filter names to activate (empty = all built-in)
# Options: email, phone, iban, tax_id, credential, money
PRIVACY_FILTERS=email,phone,iban,tax_id,credential,money

# Minimum confidence threshold to keep a detection (0.0 - 1.0)
PRIVACY_CONFIDENCE_THRESHOLD=0.4

# Anonymisation mode: "redact" (<PLACEHOLDER>) or "mask" (****)
PRIVACY_MODE=redact

# Uses a Local-LLM to filter for fuzzy PII (names, companies, addresses)
PRIVACY_LLM_FILTER=false
PRIVACY_LLM_MODEL=phi4
PRIVACY_LLM_CATEGORIES=person_name,company_name,address
